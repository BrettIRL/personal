---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import { projects } from "../lib/data/projects";
---

<section
  id="projects"
  class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
  aria-label="My Projects"
>
  <SectionHeader title="Projects" />
  <ul class="group/list">
    {
      projects.map((project) => (
        <li class="mb-12">
          <div class="group relative grid gap-4 pb-1 transition-all sm:grid-cols-8 sm:gap-8 md:gap-4 lg:group-hover/list:opacity-50 lg:hover:opacity-100!">
            <div class="absolute -inset-x-4 -inset-y-4 z-10 hidden rounded-md border border-transparent transition lg:-inset-x-6 lg:block lg:group-hover:border-slate-200/20 lg:group-hover:bg-slate-50/7.5 lg:group-hover:shadow-md lg:group-hover:drop-shadow-lg lg:dark:group-hover:border-transparent lg:dark:group-hover:bg-slate-800/50 lg:dark:group-hover:shadow-[inset_0_1px_0_0_rgba(148,163,184,0.1)]" />
            <div class="z-10 sm:order-2 sm:col-span-6">
              {project.link ? (
                <a
                  href={project.link}
                  class="inline-flex items-baseline text-base leading-tight font-medium text-slate-900 dark:text-slate-200 dark:group-hover:text-sky-300"
                  target="_blank"
                >
                  <h3>
                    {project.name}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      class="inline-block h-3 w-3 translate-y-px stroke-2 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"
                      />
                    </svg>
                  </h3>
                </a>
              ) : (
                <span class="inline-flex items-baseline text-base leading-tight font-medium text-slate-900 dark:text-slate-200 dark:group-hover:text-sky-300">
                  <h3>{project.name}</h3>
                </span>
              )}
              <p class="mt-2 text-sm leading-normal">{project.description}</p>
              {project.note && (
                <p class="mt-2 flex text-xs leading-normal">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    class="mr-1 inline-block h-4 w-4 stroke-sky-400 stroke-2 dark:stroke-sky-300"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
                    />
                  </svg>
                  {project.note}
                </p>
              )}
              <ul class="mt-2 flex flex-wrap">
                {project.technologies.map((technology) => (
                  <li class="mt-2 mr-1">
                    <div class="flex items-center rounded-md bg-sky-400/10 px-3 py-1 text-xs leading-5 font-medium text-sky-500 dark:text-sky-300">
                      {technology}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
            <Image
              alt={project.name}
              class="z-10 translate-y-1 rounded-sm border-2 border-slate-200/10 transition group-hover:border-slate-200/30 sm:order-1 sm:col-span-2"
              src={project.image}
            />
          </div>
        </li>
      ))
    }
  </ul>
</section>
