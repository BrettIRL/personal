---
import Callout from "./Callout.astro";
import ThemeToggle from "./ThemeToggle.astro";
import githubIcon from "../assets/images/github.svg?raw";
import linkedinIcon from "../assets/images/linkedin.svg?raw";
import { navMenu } from "@personal/data";
import { basic, links } from "@personal/data";
---

<header
  class="basis-[40%] lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24"
>
  <div class="z-10">
    <h1
      class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-slate-100 dark:text-slate-100"
    >
      {basic.name}
    </h1>
    <h2
      class="mt-3 text-lg font-medium tracking-tight text-slate-900 sm:text-xl lg:text-slate-100 dark:text-slate-100"
    >
      {basic.role}
    </h2>
    <p class="mt-4 max-w-xs leading-normal lg:text-slate-400">
      {basic.blurb}
    </p>
    <nav class="hidden lg:block">
      <ul class="mt-16 w-max">
        {
          navMenu.map((menuItem) => (
            <li>
              <a
                href={`#${menuItem.name.toLowerCase()}`}
                class="nav-item group flex items-center py-3"
              >
                <span class="text-xs font-bold tracking-widest text-slate-500 uppercase group-hover:text-slate-200 group-focus-visible:text-slate-200">
                  {menuItem.name}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
  <div class="flex flex-col gap-8 lg:mr-8">
    <Callout />
    <ul class="z-10 flex items-center">
      <li class="mr-2">
        <a
          href={links.github.url}
          class="flex h-8 w-8 items-center justify-center rounded-md text-slate-400 transition hover:bg-slate-900/5 lg:hover:text-slate-200 dark:hover:bg-white/5"
          rel="noopener noreferrer"
          target="_blank"
        >
          <span class="sr-only">Github</span>
          <span
            class="inline-block h-6 w-6 [&>svg]:h-full [&>svg]:w-full"
            set:html={githubIcon}
          />
        </a>
      </li>
      <li class="mr-2">
        <a
          href={links.linkedin.url}
          class="flex h-8 w-8 items-center justify-center rounded-md text-slate-400 transition hover:bg-slate-900/5 lg:hover:text-slate-200 dark:hover:bg-white/5"
          rel="noopener noreferrer"
          target="_blank"
        >
          <span class="sr-only">LinkedIn</span>
          <span
            class="inline-block h-6 w-6 [&>svg]:h-full [&>svg]:w-full"
            set:html={linkedinIcon}
          /></a
        >
      </li>
      <li class="ml-auto">
        <ThemeToggle />
      </li>
    </ul>
  </div>
</header>

<script>
  function scrollIntoView(e: Event) {
    e.preventDefault();
    const target = e.currentTarget as HTMLAnchorElement;
    const selector = target.getAttribute("href");
    if (!selector) return;
    const el = document.querySelector(selector);
    if (!el) return;
    el.scrollIntoView({
      behavior: "smooth",
    });
  }
  const navItems = document.getElementsByClassName("nav-item");
  for (const link of navItems) {
    link.addEventListener("click", scrollIntoView);
  }
</script>
